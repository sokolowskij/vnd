# LM Studio Configuration (Local Model - No OpenAI API Key Needed)
# Docker: LM Studio must run on the Docker host and listen on the network.
# Use host.docker.internal from containers, not localhost.
LOCAL_MODEL_API=http://host.docker.internal:1234/v1
OPENAI_API_KEY=local-model
OPENAI_MODEL=google/gemma-4-e4b

# Marketplace Configuration
DEFAULT_CURRENCY=PLN
POST_MODE=dry_run
HEADLESS=true

# Optional marketplaces (set to true to enable)
ENABLE_OLX=true
ENABLE_FACEBOOK=true

# Persistent paths (Docker: /app/data, Local: ./browser_profiles)
USER_DATA_DIR=/app/data/browser_profiles

# Docker/API configuration
API_HOST=0.0.0.0
API_PORT=8000
STREAMLIT_PORT=8501

# Login sessions
SESSION_TTL_DAYS=30
SESSION_COOKIE_SECURE=false

# Data retention
PENDING_RETENTION_DAYS=90
READY_RETENTION_DAYS=30
RETENTION_CHECK_HOURS=24

# Daily product-data backup email
# The backup includes product folders and ready-to-publish folders.
# It does not include auth files or browser profiles.
DAILY_BACKUP_ENABLED=false
DAILY_BACKUP_HOUR_UTC=3
ADMIN_BACKUP_EMAIL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_USE_TLS=true

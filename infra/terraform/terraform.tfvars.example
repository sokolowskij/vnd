# Copy this file to terraform.tfvars and edit it before running terraform apply.

aws_region = "eu-central-1"

# Your repo is public by default. Use an SSH URL only if you configure deploy keys.
repo_url    = "https://github.com/sokolowskij/vnd.git"
repo_branch = "master"

# Generate these with:
# ssh-keygen -t ed25519 -f ~/.ssh/vnd_aws -C "vnd-aws"
ssh_public_key_path  = "~/.ssh/vnd_aws.pub"
ssh_private_key_path = "~/.ssh/vnd_aws"

# Replace this with your public IP, for example:
# admin_cidr_blocks = ["203.0.113.10/32"]
admin_cidr_blocks = ["YOUR_PUBLIC_IP/32"]

# Leave public if the reviewer needs easy access, or restrict to their IP.
reviewer_cidr_blocks = ["0.0.0.0/0"]

instance_type       = "t3.small"
root_volume_size_gb = 24
expose_backend_api  = false
